<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dtb_moja_till_list" model="ir.ui.view">
        <field name="name">dtb.moja.till.list</field>
        <field name="model">dtb.moja.till</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="till_number"/>
                <field name="company_id"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_dtb_moja_till_form" model="ir.ui.view">
        <field name="name">dtb.moja.till.form</field>
        <field name="model">dtb.moja.till</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Till Configuration">
                        <group>
                            <field name="name"/>
                            <field name="company_id"/>
                            <field name="till_number"/>
                            <field name="is_active"/>
                        </group>
                        <group>
                            <field name="channel"/>
                            <field name="journal_id"/>
                            <field name="user_id"/>
                            <field name="password" password="True"/>
                            <field name="api_key" password="True"/>
                        </group>
                    </group>
                    <group string="Settlement Mode">
                        <group>
                            <field name="settlement_mode" widget="radio"/>
                        </group>
                        <group invisible="settlement_mode != 'core_banking'">
                            <field name="account_source"/>
                            <field name="account_id" placeholder="Bank account number"/>
                        </group>
                    </group>
                    <group string="STK Push Settings">
                        <group>
                            <field name="stk_push_url" placeholder="https://api.dtbafrica.com/till-moja/stk-push"/>
                            <field name="stk_push_callback_url" placeholder="https://your-odoo.com/api/dtb/stk-callback"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dtb_moja_till" model="ir.actions.act_window">
        <field name="name">DTB Till Config</field>
        <field name="res_model">dtb.moja.till</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_dtb_moja_root" name="DTB Moja"
              sequence="90" parent="account.menu_finance_configuration"/>
    <menuitem id="menu_dtb_moja_till" name="Till Configuration"
              parent="menu_dtb_moja_root" action="action_dtb_moja_till"/>
</odoo>
