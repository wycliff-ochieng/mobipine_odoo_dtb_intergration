<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dtb_payment_transaction_list" model="ir.ui.view">
        <field name="name">payment.transaction.dtb.list</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_list"/>
        <field name="arch" type="xml">
            <field name="reference" position="after">
                <field name="dtb_xref" optional="show"/>
                <field name="dtb_payment_method" optional="show"/>
                <field name="dtb_checkout_request_id" optional="show"/>
                <field name="dtb_till_id" optional="show"/>
                <field name="dtb_phone_number" optional="show"/>
            </field>
        </field>
    </record>

    <record id="view_dtb_payment_transaction_form" model="ir.ui.view">
        <field name="name">payment.transaction.dtb.form</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <notebook>
                    <page name="dtb" string="DTB Details" invisible="provider_id.code != 'dtb'">
                        <group>
                            <group>
                                <field name="dtb_xref"/>
                                <field name="dtb_payment_method"/>
                                <field name="dtb_customer_name"/>
                                <field name="dtb_phone_number"/>
                                <field name="dtb_till_id"/>
                                <field name="dtb_settlement_mode"/>
                            </group>
                            <group>
                                <field name="dtb_checkout_request_id"/>
                                <field name="provider_reference" string="Receipt Number"/>
                                <field name="dtb_stk_response_code"/>
                                <field name="dtb_stk_result_code"/>
                                <field name="dtb_stk_result_desc"/>
                            </group>
                        </group>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>

    <record id="action_dtb_payment_transaction" model="ir.actions.act_window">
        <field name="name">DTB Transactions</field>
        <field name="res_model">payment.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('provider_id.code', '=', 'dtb')]</field>
        <field name="context">{'search_default_provider_id': False}</field>
    </record>

    <menuitem id="menu_dtb_moja_transaction" name="Transaction Log"
              parent="menu_dtb_moja_root" action="action_dtb_payment_transaction"/>
</odoo>
